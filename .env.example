# Knowledge Base Processor Configuration
# Copy this file to .env and fill in your values

# ============================================
# Core Configuration (Required)
# ============================================

# DeepSeek API Key (required)
# Get your API key from: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_api_key

# ============================================
# Directory Configuration (Optional)
# ============================================

# Input directory (default: knowledge_input)
INPUT_DIR=knowledge_input

# Output directory (default: knowledge_output)
OUTPUT_DIR=knowledge_output

# ============================================
# API Parameters (Optional - Advanced)
# ============================================

# API model to use (default: deepseek-chat)
# Options: deepseek-chat (fast), deepseek-reasoner (more intelligent)
API_MODEL=deepseek-chat

# Maximum tokens for API response (default: 4000)
# Recommended range: 1000 - 8000
# Higher values = more detailed output, but higher cost
MAX_TOKENS=4000

# Temperature for response randomness (default: 1.0)
# Recommended range: 0.0 - 1.5
# - 0.0 = 代码生成/数学解题（最确定性）
# - 1.0 = 数据抽取/分析（本项目推荐）
# - 1.3 = 通用对话/翻译
# - 1.5 = 创意类写作/诗歌创作（最具创意）
TEMPERATURE=1.0

# Delay between API calls in seconds (default: 2)
# Recommended: 1-3 seconds to avoid rate limits
API_DELAY=2

# Maximum content length in characters (default: 50000)
# Larger files will be truncated
MAX_CONTENT_LENGTH=50000

# ============================================
# Concurrent Processing (Optional)
# ============================================

# Enable concurrent file processing (default: false)
# Set to true to process multiple files in parallel
CONCURRENT_PROCESSING=false

# Number of worker threads for concurrent processing (default: 3)
# Recommended range: 1-10 (depends on your API rate limits)
# Higher = faster but may trigger rate limits
MAX_WORKERS=3

# ============================================
# Incremental Processing (Optional)
# ============================================

# Enable incremental processing (default: true)
# Only process new or modified files since last run
INCREMENTAL_PROCESSING=true

# ============================================
# Content Deduplication (Optional)
# ============================================

# Enable content deduplication (default: true)
# Skip files that are too similar to already processed content
ENABLE_DEDUPLICATION=true

# Similarity threshold for deduplication (default: 0.85)
# Range: 0.0-1.0 (0.0 = all different, 1.0 = exactly same)
# Recommended: 0.7-0.9
DEDUPLICATION_THRESHOLD=0.85

# ============================================
# Quality Scoring (Optional)
# ============================================

# Enable quality scoring for generated content (default: true)
# Analyze and score output quality on multiple dimensions
ENABLE_QUALITY_SCORING=true
