# Knowledge Base Processor Configuration
# Copy this file to .env and fill in your values

# DeepSeek API Key (required)
# Get your API key from: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_api_key

# Input directory (optional, default: knowledge_base_link)
INPUT_DIR=knowledge_base_link

# Output directory (optional, default: processed_knowledge)
OUTPUT_DIR=processed_knowledge

# API model (optional, default: deepseek-chat)
API_MODEL=deepseek-chat

# Maximum tokens for API response (optional, default: 4000)
MAX_TOKENS=4000

# Temperature for API response (optional, default: 0.3)
TEMPERATURE=0.3

# Delay between API calls in seconds (optional, default: 2)
API_DELAY=2

# Maximum content length in characters (optional, default: 50000)
MAX_CONTENT_LENGTH=50000
